# API Конфигурация для N8N Workflow
# Скопируйте эти значения в соответствующие узлы n8n

## =====================
# BINANCE API
# =====================
BINANCE_API_KEY=YOUR_BINANCE_API_KEY
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET

# Публичные endpoints (без ключей):
# - https://api.binance.com/api/v3/klines?symbol=ETHUSDT&interval=1m&limit=200
# - https://api.binance.com/api/v3/depth?symbol=ETHUSDT&limit=100
# - https://api.binance.com/api/v3/ticker/24hr?symbol=ETHUSDT

## =====================
# NEWS API
# =====================
NEWS_API_KEY=YOUR_NEWS_API_KEY

# Endpoint: https://newsapi.org/v2/everything?q={symbol}&language=en&sortBy=publishedAt

## =====================
# TELEGRAM BOT
# =====================
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN

# Для получения Chat ID:
# 1. Напишите боту /start
# 2. Перейдите на https://api.telegram.org/bot{TOKEN}/getUpdates

## =====================
# ANTHROPIC CLAUDE API
# =====================
ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Endpoint: https://api.anthropic.com/v1/messages

## =====================
# САЙТ (clabx.ru)
# =====================
SITE_URL=https://clabx.ru
SITE_API_KEY=YOUR_SITE_API_KEY
N8N_VPS_URL=http://91.219.151.7:5678

# API Endpoints на сайте:
# POST /api/trading-signal - отправить сигнал
# GET /api/analyze?symbol=ETHUSDT - получить анализ

## =====================
# НАСТРОЙКИ РИСК-МЕНЕДЖМЕНТА
# =====================
MIN_CONFIDENCE=0.65          # Минимальная уверенность для открытия сделки (65%)
MAX_RISK_PERCENT=2           # Максимальный риск от депозита (%)
MIN_SPREAD_PERCENT=0.1        # Максимальный спред для входа (0.1%)
